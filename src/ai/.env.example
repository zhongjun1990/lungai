# AI Service Configuration
NODE_ENV=development

# Server
AI_SERVER_PORT=9000
AI_SERVER_HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://admin:password123@localhost:27017/medical_metadata?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Message Queue
RABBITMQ_URL=amqp://admin:password123@localhost:5672/

# MinIO Object Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_SECURE=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=dicom-storage

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# Model Configuration
LUNG_NODULE_MODEL_PATH=./models/lung-nodule-detector
LUNG_NODULE_MODEL_VERSION=v1.0.0
LUNG_NODULE_THRESHOLD=0.7

CHEST_XRAY_MODEL_PATH=./models/chest-xray-classifier
CHEST_XRAY_MODEL_VERSION=v1.0.0
CHEST_XRAY_THRESHOLD=0.6
