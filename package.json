{
  "name": "ai-medical-imaging-saas",
  "version": "1.0.0",
  "description": "AI 医疗影像分析 SaaS 平台",
  "repository": "https://github.com/your-repo/ai-medical-imaging",
  "author": "Your Team",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "src/web",
    "src/api",
    "src/ai",
    "src/mobile"
  ],
  "scripts": {
    "dev": "docker-compose up",
    "dev:services": "docker-compose up -d postgres redis minio mongodb elasticsearch rabbitmq",
    "dev:api": "cd src/api && npm run dev",
    "dev:web": "cd src/web && npm run dev",
    "dev:ai": "cd src/ai && npm run dev",
    "build": "npm run build:api && npm run build:ai && npm run build:web",
    "build:api": "cd src/api && npm run build",
    "build:ai": "cd src/ai && npm run build",
    "build:web": "cd src/web && npm run build",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:integration": "jest tests/integration",
    "test:e2e": "cypress run",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "db:migrate": "cd src/api && npm run db:migrate",
    "db:seed": "cd src/api && npm run db:seed",
    "db:reset": "cd src/api && npm run db:reset",
    "compose:up": "docker-compose up -d",
    "compose:down": "docker-compose down",
    "compose:logs": "docker-compose logs -f",
    "compose:restart": "docker-compose restart",
    "compose:clean": "docker-compose down -v --remove-orphans",
    "health:check": "node scripts/healthcheck.js",
    "setup": "npm run compose:up"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "prettier": "^2.8.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "medical-imaging",
    "ai",
    "dicom",
    "pacs",
    "healthcare",
    "saas"
  ]
}
