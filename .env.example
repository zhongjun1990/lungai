# AI 医疗影像分析 SaaS - 环境变量示例
# 复制此文件为 .env 并根据需要修改配置

# ========== 应用配置 ==========
APP_NAME=Medical Imaging AI
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000

# ========== 数据库配置 ==========
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
DATABASE_URL=postgres://admin:password123@localhost:5432/medical_db

# MongoDB
MONGODB_URI=mongodb://admin:password123@localhost:27017/medical_metadata?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 对象存储配置 (MinIO / S3) ==========
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=dicom-storage
MINIO_SECURE=false

# AWS S3 (生产环境使用)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=medical-dicom-storage

# ========== Elasticsearch 配置 ==========
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://localhost:9200

# ========== RabbitMQ 配置 ==========
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=password123
RABBITMQ_VHOST=medical-vhost
RABBITMQ_URL=amqp://admin:password123@localhost:5672/medical-vhost

# ========== JWT 认证配置 ==========
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ========== AI 模型配置 ==========
MODEL_REPO_PATH=./models
INFERENCE_URL=http://localhost:8001/v2
MODEL_VERSION=v1.0.0
CUDA_VISIBLE_DEVICES=0

# ========== 日志配置 ==========
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_FILE=app.log

# ========== 监控配置 ==========
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ========== 医疗合规配置 ==========
HIPAA_ENABLED=true
AUDIT_LOG_ENABLED=true
ENCRYPTION_KEY=your-encryption-key-change-in-production
KEY_ROTATION_DAYS=90

# ========== 邮件配置 ==========
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@medical-imaging-ai.com
